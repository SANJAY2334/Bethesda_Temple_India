# Frontend Environment Configuration

# API URL - Where the backend API is hosted
# For development: use relative path /api (Vite proxy will forward to localhost:5000)
# For production: set to your actual backend domain (e.g., https://api.graceharbor.church)
VITE_API_URL=/api

# Site URL - Your website domain
# Used for sitemap and canonical URLs
VITE_SITE_URL=https://graceharbor.church
